{
  "permissions": {
      "allow": [
          "Bash(git:*)",
          "Bash(grep:*)",
          "Bash(mkdir:*)",
          "Bash(cp:*)",
          "Bash(echo:*)",
          "Read",
          "Glob",
          "Grep",
          "mcp__plugin_supabase_supabase__list_*",
          "mcp__plugin_supabase_supabase__get_*",
          "mcp__plugin_supabase_supabase__generate_typescript_types",
          "mcp__plugin_supabase_supabase__confirm_cost"
      ],
      "deny": [
        "Bash(sudo:*)",
        "Bash(rm:*)",
        "Bash(rm -rf:*)",
        "Read(.env.*)",
        "Read(id_rsa)",
        "Read(id_ed25519)",
        "Write(.env*)",
        "Bash(git push:*)",
        "Bash(curl:*)",
        "Bash(wget:*)",
        "Bash(nc:*)"
      ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; pnpm exec oxfmt \"$f\"; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "env":{
    "ANTHROPIC_MODEL":"opusplan",
    "ENABLE_TOOL_SEARCH" : true,
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_ENABLE_STREAM_WATCHDOG" : "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE" : "70",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "MAX_THINKING_TOKENS": "0"
  }
}
